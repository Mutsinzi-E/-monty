#include "monty.h"

/**
 * add - adds top two elements
 */
void add(stack_t **stack, unsigned int line_number)
{
    stack_t *tmp;
    int sum;

    if (!stack || !*stack || !(*stack)->next)
    {
        fprintf(stderr, "L%u: can't add, stack too short\n", line_number);
        exit(EXIT_FAILURE);
    }

    tmp = *stack;

    sum = tmp->n + tmp->next->n;
    tmp->next->n = sum;

    *stack = tmp->next;
    (*stack)->prev = NULL;

    free(tmp);
}
