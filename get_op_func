#include "monty.h"
#include <string.h>

void (*get_op_func(char *opcode))(stack_t **, unsigned int)
{
    int i = 0;

    instruction_t ops[] = {
        {"push", push},
        {"pall", pall},
        {"pint", pint},
        {"pop", pop},

        {"swap", swap},

        {"add", add},
        {"sub", sub},
        {"div", divi},
        {"mul", mul},
        {"mod", mod},

        {"nop", nop},
        {"pchar", pchar},
        {"pstr", pstr},

        {"rotl", rotl},
        {"rotr", rotr},

        {NULL, NULL}
    };

    if (!opcode)
        return NULL;

    while (ops[i].opcode)
    {
        if (strcmp(ops[i].opcode, opcode) == 0)
            return ops[i].f;
        i++;
    }

    return NULL;
}
