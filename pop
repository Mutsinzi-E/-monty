#include "monty.h"

/**
 * pop - removes top element
 */
void pop(stack_t **stack, unsigned int line_number)
{
    stack_t *tmp;

    if (!stack || !*stack)
    {
        fprintf(stderr, "L%u: can't pop an empty stack\n", line_number);
        exit(EXIT_FAILURE);
    }

    tmp = *stack;
    *stack = (*stack)->next;

    if (*stack)
        (*stack)->prev = NULL;

    free(tmp);
}
